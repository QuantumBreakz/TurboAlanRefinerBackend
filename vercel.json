{
  "version": 2,
  "builds": [
    {
      "src": "api/vercel_handler.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/vercel_handler.py"
    }
  ],
  "functions": {
    "api/vercel_handler.py": {
      "maxDuration": 300,
      "memory": 1024
    }
  }
}